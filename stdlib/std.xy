/**
 * @file stdlib/std.xy
 * @brief 玄语标准库入口
 * @description 导入所有标准库模块
 *
 * 使用方法:
 * 引入 "stdlib/std.xy"
 */

// 导入字符串处理模块
引入 "string.xy"

// 导入数组操作模块
引入 "array.xy"

// 导入数学工具模块
引入 "math.xy"

// 导入输入输出模块
引入 "io.xy"

/**
 * 标准库版本信息
 */
定义 常量 标准库版本: 文本 = "0.1.0"
定义 常量 标准库名称: 文本 = "玄语标准库"

/**
 * 打印标准库信息
 */
函数 打印标准库信息() {
    打印标题(标准库名称)
    打印文本("版本: ")
    打印文本(标准库版本)
    打印换行()
    打印文本("模块:")
    打印换行()
    打印文本("  - string: 字符串处理")
    打印换行()
    打印文本("  - array:  数组操作")
    打印换行()
    打印文本("  - math:   数学工具")
    打印换行()
    打印文本("  - io:     输入输出")
    打印换行()
}
