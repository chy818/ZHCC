/**
 * @file stdlib/math.xy
 * @brief 数学工具标准库
 */

/**
 * 绝对值
 */
函数 绝对值(数值: 整数): 整数 {
    若 数值 < 0 则 {
        返回 -数值
    }
    返回 数值
}

/**
 * 最大公约数
 */
函数 最大公约数(甲: 整数, 乙: 整数): 整数 {
    定义 可变 a = 绝对值(甲)
    定义 可变 b = 绝对值(乙)

    循环 b != 0 {
        定义 临时 = b
        b = a % b
        a = 临时
    }

    返回 a
}
