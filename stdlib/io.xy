/**
 * @file stdlib/io.xy
 * @brief 输入输出标准库
 * @description 提供输入输出的工具函数
 */

/**
 * 打印整数
 */
函数 打印整数(数值: 整数) {
    外部 "print_int"
}

/**
 * 打印文本
 */
函数 打印文本(文本: 文本) {
    外部 "print_string"
}

/**
 * 打印布尔值
 */
函数 打印布尔值(数值: 布尔) {
    若 数值 则 {
        打印文本("真")
    } 否则 {
        打印文本("假")
    }
}

/**
 * 打印换行
 */
函数 打印换行() {
    打印文本("\n")
}

/**
 * 打印标题
 */
函数 打印标题(标题: 文本) {
    打印文本(标题)
    打印换行()
}

/**
 * 读取整数
 */
函数 读取整数(): 整数 {
    外部 "read_int"
}
