/**
 * @file file_io_test.xy
 * @brief 文件 I/O 测试程序
 * @description 测试玄语的文件读写功能
 */

引入 "stdlib/io.xy"

/**
 * 主函数
 */
函数 主(): 整数 {
    打印标题("=== 文件 I/O 测试 ===")
    打印换行()
    
    定义 可变 测试路径: 文本
    测试路径 = "test_output.txt"
    
    /* 测试 1: 写入文件 */
    打印标题("测试 1: 写入文件")
    定义 可变 写入内容: 文本
    写入内容 = "这是一个测试文件\n" + "Hello, 玄语!\n" + "测试文件写入功能\n"
    
    定义 可变 写入结果: 整数
    写入结果 = 写入文件(测试路径, 写入内容)
    
    若 写入结果 == 0 则 {
        打印文本("✓ 文件写入成功!\n")
    } 否则 {
        打印文本("✗ 文件写入失败!\n")
        返回 -1
    }
    打印换行()
    
    /* 测试 2: 检查文件是否存在 */
    打印标题("测试 2: 检查文件是否存在")
    定义 可变 存在: 布尔
    存在 = 文件存在(测试路径)
    
    若 存在 则 {
        打印文本("✓ 文件存在检查通过!\n")
    } 否则 {
        打印文本("✗ 文件不存在!\n")
        返回 -1
    }
    打印换行()
    
    /* 测试 3: 读取文件 */
    打印标题("测试 3: 读取文件")
    定义 可变 读取内容: 文本
    读取内容 = 读取文件(测试路径)
    
    若 读取内容 != "" 则 {
        打印文本("✓ 文件读取成功!\n")
        打印文本("文件内容:\n")
        打印文本("----------------\n")
        打印文本(读取内容)
        打印文本("----------------\n")
    } 否则 {
        打印文本("✗ 文件读取失败或为空!\n")
        返回 -1
    }
    打印换行()
    
    /* 测试 4: 追加内容到文件 */
    打印标题("测试 4: 追加内容到文件")
    定义 可变 追加内容: 文本
    追加内容 = "这是追加的内容\n"
    
    定义 可变 追加结果: 整数
    追加结果 = 追加文件(测试路径, 追加内容)
    
    若 追加结果 == 0 则 {
        打印文本("✓ 文件追加成功!\n")
    } 否则 {
        打印文本("✗ 文件追加失败!\n")
        返回 -1
    }
    打印换行()
    
    /* 再次读取验证追加 */
    打印标题("验证追加内容")
    定义 可变 追加后内容: 文本
    追加后内容 = 读取文件(测试路径)
    
    打印文本("追加后的文件内容:\n")
    打印文本("----------------\n")
    打印文本(追加后内容)
    打印文本("----------------\n")
    打印换行()
    
    /* 测试 5: 复制文件 */
    打印标题("测试 5: 复制文件")
    定义 可变 复制路径: 文本
    复制路径 = "test_copy.txt"
    
    定义 可变 复制结果: 整数
    复制结果 = 复制文件(测试路径, 复制路径)
    
    若 复制结果 == 0 则 {
        打印文本("✓ 文件复制成功!\n")
    } 否则 {
        打印文本("✗ 文件复制失败!\n")
        返回 -1
    }
    打印换行()
    
    /* 验证复制文件 */
    打印标题("验证复制文件")
    定义 可变 复制文件存在: 布尔
    复制文件存在 = 文件存在(复制路径)
    
    若 复制文件存在 则 {
        打印文本("✓ 复制文件存在验证通过!\n")
    } 否则 {
        打印文本("✗ 复制文件不存在!\n")
        返回 -1
    }
    打印换行()
    
    /* 测试 6: 删除文件 */
    打印标题("测试 6: 删除文件")
    定义 可变 删除结果1: 整数
    删除结果1 = 删除文件(测试路径)
    
    定义 可变 删除结果2: 整数
    删除结果2 = 删除文件(复制路径)
    
    若 删除结果1 == 0 且 删除结果2 == 0 则 {
        打印文本("✓ 文件删除成功!\n")
    } 否则 {
        打印文本("✗ 文件删除失败!\n")
    }
    打印换行()
    
    /* 验证文件已删除 */
    打印标题("验证文件已删除")
    定义 可变 原文件存在: 布尔
    原文件存在 = 文件存在(测试路径)
    
    定义 可变 复制文件还存在: 布尔
    复制文件还存在 = 文件存在(复制路径)
    
    若 !原文件存在 且 !复制文件还存在 则 {
        打印文本("✓ 文件删除验证通过!\n")
    } 否则 {
        打印文本("✗ 文件仍然存在!\n")
    }
    打印换行()
    
    /* 测试 7: 命令执行测试 */
    打印标题("测试 7: 命令执行")
    定义 可变 命令: 文本
    命令 = "echo Hello from command"
    
    定义 可变 命令输出内容: 文本
    命令输出内容 = 命令输出(命令)
    
    若 命令输出内容 != "" 则 {
        打印文本("✓ 命令执行成功!\n")
        打印文本("命令输出: ")
        打印文本(命令输出内容)
        打印换行()
    } 否则 {
        打印文本("✗ 命令执行失败或无输出!\n")
    }
    打印换行()
    
    打印标题("=== 所有测试完成 ===")
    打印文本("✓ 文件 I/O 功能测试通过!\n")
    
    返回 0
}
