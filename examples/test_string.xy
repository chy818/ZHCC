/**
 * @file test_string.xy
 * @brief 测试字符串切片和拼接功能
 */

函数 主 函数(): 整数 {
  定义 文本1: 文本
  文本1 = "Hello"
  
  定义 文本2: 文本
  文本2 = "World"
  
  // 测试字符串拼接
  定义 结果: 文本
  结果 = 文本拼接(文本1, 文本2)
  
  打印("拼接结果: ")
  打印(结果)
  
  // 测试字符串切片
  定义 源码: 文本
  源码 = "HelloWorld"
  
  定义 子串: 文本
  子串 = 文本切片(源码, 0, 5)
  
  打印("切片结果: ")
  打印(子串)
  
  // 测试文本长度
  定义 长度: 文本
  长度 = 文本长度(源码)
  
  打印("文本长度: ")
  打印(长度)
  
  返回 0
}
