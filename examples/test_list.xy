/**
 * @file test_list.xy
 * @brief 测试列表功能
 */

函数 主 函数(): 整数 {
  // 创建列表
  定义 列表: 文本
  列表 = 创建列表(10)
  
  // 添加元素
  列表添加(列表, 1)
  列表添加(列表, 2)
  列表添加(列表, 3)
  
  // 获取长度
  定义 长度: 整数
  长度 = 列表长度(列表)
  
  打印("列表长度: ")
  打印整数(长度)
  
  // 获取元素
  定义 元素: 整数
  元素 = 列表获取(列表, 0)
  
  打印("第一个元素: ")
  打印整数(元素)
  
  元素 = 列表获取(列表, 1)
  打印("第二个元素: ")
  打印整数(元素)
  
  返回 0
}
