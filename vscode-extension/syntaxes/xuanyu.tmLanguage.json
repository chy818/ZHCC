{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "玄语 (XY Language)",
  "scopeName": "source.xuanyu",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.xuanyu",
          "match": "//.*$"
        },
        {
          "name": "comment.block.xuanyu",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#doc-comments"
            }
          ]
        }
      ]
    },
    "doc-comments": {
      "patterns": [
        {
          "name": "keyword.other.doc.xuanyu",
          "match": "@(param|return|description|file|brief|author|version|see|example)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.xuanyu",
          "match": "\\b(函数|返回|若|否则|则|循环|当|中断|跳过|导入|导出|外部|定义|常量|可变|结构体|枚举|类型|类|接口|实现|扩展|匹配|情况|默认|抛出|捕获|尝试|最终|异步|等待)\\b"
        },
        {
          "name": "keyword.control.english.xuanyu",
          "match": "\\b(func|return|if|else|then|loop|while|break|continue|import|export|extern|let|const|mut|struct|enum|type|class|interface|impl|extends|match|case|default|throw|catch|try|finally|async|await)\\b"
        },
        {
          "name": "constant.language.xuanyu",
          "match": "\\b(真|假|空|True|False|Null)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.xuanyu",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.xuanyu",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.xuanyu",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.xuanyu",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.xuanyu",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.xuanyu",
          "match": "\\b\\d+\\b"
        },
        {
          "name": "constant.numeric.hex.xuanyu",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.xuanyu",
          "match": "\\b0[bB][01]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.xuanyu",
          "match": "(\\+|\\-|\\*|\\/|\\%|\\+\\+|\\-\\-)"
        },
        {
          "name": "keyword.operator.comparison.xuanyu",
          "match": "(==|!=|<|>|<=|>=)"
        },
        {
          "name": "keyword.operator.logical.xuanyu",
          "match": "(且|或|非|\\&\\&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.xuanyu",
          "match": "(=|\\+=|\\-=|\\*=|\\/=|\\%=)"
        },
        {
          "name": "keyword.operator.bitwise.xuanyu",
          "match": "(&|\\||\\^|~|<<|>>)"
        },
        {
          "name": "keyword.operator.arrow.xuanyu",
          "match": "(->|=>)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.xuanyu",
          "match": "\\b([\\u4e00-\\u9fa5a-zA-Z_][\\u4e00-\\u9fa5a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.xuanyu",
          "match": "\\b(整数|浮点|布尔|文本|空类型|Int|Float|Bool|String|Void|Long|Double)\\b"
        },
        {
          "name": "support.type.collection.xuanyu",
          "match": "\\b(列表|数组|映射|集合|List|Array|Map|Set)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.xuanyu",
          "match": "\\b[\\u4e00-\\u9fa5a-zA-Z_][\\u4e00-\\u9fa5a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
