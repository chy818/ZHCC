/**
 * @file runtime_xy/io.xy
 * @brief XY 语言 IO 运行时
 * @description 用 XY 语言实现的 IO 函数
 */

/**
 * 打印整数
 * @param val 整数值
 */
函数 打印整数(值: 整数) {
    外部 "print_int"(值)
}

/**
 * 打印文本
 * @param str 字符串
 */
函数 打印文本(文本: 文本) {
    外部 "print"(文本)
}

/**
 * 打印换行
 */
函数 打印换行() {
    外部 "print"("\n")
}

/**
 * 读取整数
 * @return 整数
 */
函数 读取整数(): 整数 {
    返回 外部 "输入整数"()
}
