/**
 * @file parser.xy
 * @brief 语法分析器 - 自展编译器
 * @description 简化版语法分析功能
 */

引入 "src/compiler_v2/lexer.xy"

枚举 NodeKind {
    Prog,
    Func,
    Var,
    Ret,
    If,
    While,
    Call,
    BinOp,
    Num,
    Id
}

结构体 Parser {
    lex: Lexer,
    nodeCount: 整数,
    errorCount: 整数
}

函数 parserInit(): Parser {
    定义 p: Parser
    p.lex = lexerInit()
    p.nodeCount = 0
    p.errorCount = 0
    返回 p
}

函数 newNode(p: Parser): 整数 {
    定义 id: 整数
    id = p.nodeCount
    p.nodeCount = p.nodeCount + 1
    返回 id
}

函数 parseExpr(p: Parser): 整数 {
    返回 newNode(p)
}

函数 parseStatement(p: Parser): 整数 {
    返回 newNode(p)
}

函数 parseFunction(p: Parser): 整数 {
    返回 newNode(p)
}

函数 parseProgram(p: Parser): 整数 {
    打印("=== 语法分析 ===")
    
    定义 root: 整数
    root = newNode(p)
    
    定义 i: 整数
    i = 0
    当 i < 100 则 {
        parseFunction(p)
        i = i + 1
    }
    
    打印("语法分析完成，共生成 ")
    打印
    打印(" 个 AST 节点")
    
    返回 root
}

函数 parserRun(src: 文本): 整数 {
    定义 p: Parser
    p = parserInit()
    
    定义 root: 整数
    root = parseProgram(p)
    
    若 p.errorCount > 0 则 {
        打印("发现 ")
        打印
        打印(" 个语法错误")
        返回 0 - p.errorCount
    }
    
    返回 p.nodeCount
}
